:4000 {
	# Serve auto-login page for the owner
	handle /owner-login {
		root * /app/static
		rewrite * /owner-login.html
		file_server
	}

	# Proxy to Bulwark, strip frame-ancestors CSP so the iframe auto-login works
	handle {
		reverse_proxy localhost:3000 {
			header_down -Content-Security-Policy
		}
	}
}
