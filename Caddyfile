:4000 {
	# Redirect / to auto-login if no session cookie
	@root_no_session {
		path /
		not header Cookie *jmap_session*
	}
	redir @root_no_session /owner-login temporary

	# Owner auto-login via session API
	handle /owner-login {
		reverse_proxy localhost:3001
	}

	# JMAP consumer proxy: strips /jmap-proxy prefix, forwards to sidecar
	# which translates into v2 service proxy calls.
	handle_path /jmap-proxy/* {
		reverse_proxy localhost:3002
	}

	# Everything else to Bulwark
	handle {
		reverse_proxy localhost:3000
	}
}
