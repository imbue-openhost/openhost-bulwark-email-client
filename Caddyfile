:4000 {
	# Redirect root to auto-login
	@root path /
	redir @root /owner-login temporary

	# Serve auto-login page for the owner
	handle /owner-login {
		root * /app/static
		rewrite * /owner-login.html
		file_server
	}

	# Proxy to Bulwark via inject-proxy (strips CSP, injects auto-login script)
	handle {
		reverse_proxy localhost:3001
	}
}
